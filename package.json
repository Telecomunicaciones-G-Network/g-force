{
  "name": "@gnetwork/gforce",
  "version": "0.0.37",
  "private": true,
  "author": "Telecomunicaciones GNetwork @ <desarrollo@gnetworkve.com>",
  "bugs": {
    "url": "https://github.com/Telecomunicaciones-G-Network/g-force.git/issues"
  },
  "description": "Telecomunicaciones Gnetwork @ G-Force",
  "engines": {
    "node": ">=24.13.0",
    "bun": ">=1.3.0"
  },
  "homepage": "https://github.com/Telecomunicaciones-G-Network/g-force.git",
  "keywords": [
    "GNetwork",
    "G-Force App"
  ],
  "license": "GNETWORK",
  "packageManager": "bun@1.3.9",
