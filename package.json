    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Telecomunicaciones-G-Network/g-force.git"
  },
  "scripts": {
    "analize:packages": "npx fix-react2shell-next",
    "build": "run-s clean compile",
    "check": "biome check",
