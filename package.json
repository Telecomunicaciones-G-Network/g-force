    "compile": "next build",
    "dev": "next dev",
    "format": "biome format --write",
    "husky": "husky",
    "lint": "biome lint --write",
    "security:scan": "trivy fs --scanners vuln,secret,misconfig ./",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
