{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "GNetwork GForce App",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["./src/app/*"],
      "@modules/*": ["./src/modules/*"],
      "@module-auth/*": ["./src/modules/auth/*"],
      "@module-chat/*": ["./src/modules/chat/*"],
      "@module-contract/*": ["./src/modules/contract/*"],
      "@module-core/*": ["./src/modules/core/*"],
      "@module-invoice/*": ["./src/modules/invoice/*"],
      "@module-payment/*": ["./src/modules/payment/*"],
      "@module-ticket/*": ["./src/modules/ticket/*"],
      "@module-user/*": ["./src/modules/user/*"],
      "@crypto/*": ["./src/packages/crypto/*"],
      "@filer/*": ["./src/packages/filer/*"],
      "@gnetwork-ui/*": ["./src/packages/gnetwork-ui/*"],
      "@hook/*": ["./src/packages/hook/*"],
      "@http-client/*": ["./src/packages/http-client/*"],
      "@logger/*": ["./src/packages/logger/*"],
      "@next-tools/*": ["./src/packages/next-tools/*"],
      "@next-ui/*": ["./src/packages/next-ui/*"],
      "@objecter/*": ["./src/packages/objecter/*"],
      "@regexs/*": ["./src/packages/regexs/*"],
      "@socketio/*": ["./src/packages/socketio/*"],
      "@sounder/*": ["./src/packages/sounder/*"],
      "@stringify/*": ["./src/packages/stringify/*"],
      "@timer/*": ["./src/packages/timer/*"],
      "@ui-auth/*": ["./src/ui/auth/*"],
      "@ui-chat/*": ["./src/ui/chat/*"],
      "@ui-contract/*": ["./src/ui/contract/*"],
      "@ui-core/*": ["./src/ui/core/*"],
      "@ui-packages/*": ["./src/ui/packages/*"],
      "@ui-payment/*": ["./src/ui/payment/*"],
      "@ui-ticket/*": ["./src/ui/ticket/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "target": "ES2017",
    "typeRoots": ["./node_modules/@types", "./src/@types"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
